{$APP_DOMAIN} {
    encode gzip zstd

    header {
        X-Content-Type-Options nosniff
        Referrer-Policy strict-origin-when-cross-origin
        Content-Security-Policy "frame-ancestors 'self' https://www.notion.so https://notion.so;"
    }

    reverse_proxy app:8000
}
